# =============================================================================
# 005_AI_Project -- Environment Variables Example
# =============================================================================
# 이 파일은 필요한 환경변수 목록을 문서화하는 참고용입니다.
#
# 실제 사용:
# 1. .mcp.json의 env 필드에 직접 입력 (Claude Code 방식)
# 2. 또는 OS 시스템 환경변수로 설정
#
# 복사 방법:
# cp .env.example .env
# (단, 현재 Claude Code MCP 로더는 .env 자동 로드를 공식 지원하지 않음)
# =============================================================================

# --- Firecrawl (웹 크롤링/스크래핑) ---
# 획득: https://firecrawl.dev/
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# --- Fal AI (AI 미디어 생성) ---
# 획득: https://fal.ai/
FAL_KEY=your_fal_key_here

# --- Exa (시맨틱 웹 검색) ---
# 획득: https://exa.ai/
EXA_API_KEY=your_exa_api_key_here

# --- Jira / Confluence (Atlassian) ---
# 획득: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://your-domain.atlassian.net
JIRA_EMAIL=your_email@example.com
JIRA_API_TOKEN=your_jira_api_token_here
CONFLUENCE_URL=https://your-domain.atlassian.net/wiki
CONFLUENCE_EMAIL=your_email@example.com
CONFLUENCE_API_TOKEN=your_confluence_api_token_here

# --- Supabase (MCP HTTP) ---
# 획득: https://supabase.com/dashboard/project/_/settings/general
SUPABASE_PROJECT_REF=your_project_ref_here
