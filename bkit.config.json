{
  "$schema": "./bkit.config.schema.json",
  "version": "2.0.8",
  "pdca": {
    "docPaths": {
      "plan": [
        "docs/01-plan/features/{feature}.plan.md",
        "docs/01-plan/{feature}.plan.md"
      ],
      "design": [
        "docs/02-design/features/{feature}.design.md",
        "docs/02-design/{feature}.design.md"
      ],
      "analysis": [
        "docs/03-analysis/{feature}.analysis.md"
      ],
      "report": [
        "docs/04-report/features/{feature}.report.md",
        "docs/04-report/{feature}.report.md"
      ],
      "archive": "docs/archive/{date}/{feature}"
    },
    "matchRateThreshold": 85,
    "autoIterate": true,
    "maxIterations": 3,
    "requireDesignDoc": false,
    "automationLevel": "semi-auto",
    "autoStartThreshold": 100,
    "fullAuto": {
      "reviewCheckpoints": ["design"]
    }
  },
  "triggers": {
    "implicitEnabled": true,
    "confidenceThreshold": 0.7,
    "clarifyAmbiguity": true
  },
  "pipeline": {
    "autoTransition": false,
    "skipConfirmation": false
  },
  "multiFeature": {
    "maxActiveFeatures": 3,
    "autoSwitch": true
  },
  "featurePatterns": [
    "features",
    "Projects",
    "skills"
  ],
  "fileDetection": {
    "sourceExtensions": [".py", ".md", ".hwpx", ".json", ".docx", ".pptx"],
    "excludePatterns": [
      "node_modules", ".git", "dist", "build",
      "__pycache__", ".cache", "venv", "Temporary Storage",
      "Output", "Log"
    ]
  },
  "cache": {
    "enabled": true,
    "ttl": 5000
  },
  "permissions": {
    "Write": "allow",
    "Edit": "allow",
    "Read": "allow",
    "Bash": "allow",
    "Bash(rm -rf*)": "deny",
    "Bash(rm -r*)": "ask",
    "Bash(git push --force*)": "deny",
    "Bash(git reset --hard*)": "ask"
  },
  "automation": {
    "defaultLevel": 2,
    "trustScoreEnabled": true,
    "autoEscalation": false,
    "autoDowngrade": true,
    "maxConcurrentFeatures": 2,
    "gateTimeoutMs": 300000,
    "emergencyStopEnabled": true
  },
  "guardrails": {
    "destructiveDetection": true,
    "loopBreaker": {
      "maxPdcaIterations": 3,
      "maxSameFileEdits": 10,
      "maxAgentRecursion": 3,
      "cooldownMs": 60000
    },
    "blastRadiusLimit": "medium",
    "checkpointOnPhaseTransition": true,
    "checkpointOnDestructive": true
  },
  "quality": {
    "gateEnabled": true,
    "metricsCollection": true,
    "regressionGuard": true,
    "thresholds": {
      "matchRate": 85,
      "codeQualityScore": 70,
      "criticalIssueCount": 0,
      "conventionCompliance": 85
    }
  },
  "team": {
    "enabled": true,
    "displayMode": "in-process",
    "maxTeammates": 3,
    "delegateMode": false
  }
}
